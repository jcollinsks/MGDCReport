{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.5.0/schema.json",
  "name": "v_sens_bar_protection",
  "position": {"x": 420, "y": 140, "z": 2000, "height": 250, "width": 410, "tabOrder": 2000},
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [{
            "field": {
              "Column": {
                "Expression": {"SourceRef": {"Entity": "SharePointFiles"}},
                "Property": "SecurityStatus"
              }
            },
            "queryRef": "SharePointFiles.SecurityStatus",
            "active": true
          }]
        },
        "Y": {
          "projections": [{
            "field": {
              "Measure": {
                "Expression": {"SourceRef": {"Entity": "_Measures"}},
                "Property": "Total Files"
              }
            },
            "queryRef": "_Measures.Total Files"
          }]
        }
      }
    },
    "visualContainerObjects": {
      "title": [{"properties": {
        "show": {"expr": {"Literal": {"Value": "true"}}},
        "text": {"expr": {"Literal": {"Value": "'File Protection Status'"}}}
      }}]
    }
  }
}
