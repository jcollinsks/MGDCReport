{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.5.0/schema.json",
  "name": "v_ua_bar_clients",
  "position": {"x": 850, "y": 140, "z": 3000, "height": 250, "width": 400, "tabOrder": 3000},
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [{
            "field": {
              "Column": {
                "Expression": {"SourceRef": {"Entity": "SPOFileActions"}},
                "Property": "UserAgentCategory"
              }
            },
            "queryRef": "SPOFileActions.UserAgentCategory",
            "active": true
          }]
        },
        "Y": {
          "projections": [{
            "field": {
              "Measure": {
                "Expression": {"SourceRef": {"Entity": "_Measures"}},
                "Property": "Total Actions"
              }
            },
            "queryRef": "_Measures.Total Actions"
          }]
        }
      }
    },
    "visualContainerObjects": {
      "title": [{"properties": {
        "show": {"expr": {"Literal": {"Value": "true"}}},
        "text": {"expr": {"Literal": {"Value": "'Client Application Distribution'"}}}
      }}]
    }
  }
}
