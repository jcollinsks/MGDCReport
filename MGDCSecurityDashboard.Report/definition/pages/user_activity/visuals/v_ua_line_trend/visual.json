{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.5.0/schema.json",
  "name": "v_ua_line_trend",
  "position": {"x": 20, "y": 140, "z": 1000, "height": 250, "width": 380, "tabOrder": 1000},
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [{
            "field": {
              "Column": {
                "Expression": {"SourceRef": {"Entity": "SPOFileActions"}},
                "Property": "ActionDate"
              }
            },
            "queryRef": "SPOFileActions.ActionDate",
            "active": true
          }]
        },
        "Y": {
          "projections": [{
            "field": {
              "Measure": {
                "Expression": {"SourceRef": {"Entity": "_Measures"}},
                "Property": "Total Actions"
              }
            },
            "queryRef": "_Measures.Total Actions"
          }]
        }
      }
    },
    "visualContainerObjects": {
      "title": [{"properties": {
        "show": {"expr": {"Literal": {"Value": "true"}}},
        "text": {"expr": {"Literal": {"Value": "'Daily Activity Trend'"}}}
      }}]
    }
  }
}
