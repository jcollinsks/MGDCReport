		dataType: string
		lineageTag: c1a00001-0001-0001-0001-000000000125
		summarizeBy: none
		sourceColumn: Privacy

		annotation SummarizationSetBy = Automatic

	column CalcSiteRiskScore =
		VAR _ExternalSharing = IF([IsExternalSharingEnabled], 25, 0)
		VAR _NoLabel = IF(ISBLANK([SensitivityLabelInfo.Id]), 20, 0)
		VAR _NoDevicePolicy = IF(NOT([BlockAccessFromUnmanagedDevices]), 15, 0)
		VAR _Orphaned = IF(ISBLANK([Owner.Email]), 15, 0)
		VAR _Stale = IF(DATEDIFF([LastContentChange], TODAY(), DAY) > 180, 15, 0)
		VAR _ReadLocked = IF([ReadLocked], 10, 0)
		RETURN _ExternalSharing + _NoLabel + _NoDevicePolicy + _Orphaned + _Stale + _ReadLocked
		dataType: int64
		lineageTag: c1a00001-0001-0001-0001-000000000201
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column SiteRiskTier = SWITCH(TRUE(), [CalcSiteRiskScore] >= 75, "Critical", [CalcSiteRiskScore] >= 50, "High", [CalcSiteRiskScore] >= 25, "Medium", "Low")
		dataType: string
		lineageTag: c1a00001-0001-0001-0001-000000000202
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column SiteType = SWITCH(TRUE(), [IsOneDrive], "Personal", [IsCommunicationSite], "Communication", "Team")
		dataType: string
		lineageTag: c1a00001-0001-0001-0001-000000000203
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column StorageUsedGB = DIVIDE([StorageUsed], 1073741824, 0)
		dataType: double
		lineageTag: c1a00001-0001-0001-0001-000000000204
		summarizeBy: none
		formatString: #,0.00

		annotation SummarizationSetBy = Automatic

	column DaysSinceModified = DATEDIFF([LastContentChange], TODAY(), DAY)
		dataType: int64
		lineageTag: c1a00001-0001-0001-0001-000000000205
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column ExternalSharingRiskLevel = IF([IsExternalSharingEnabled], "High", "Low")
		dataType: string
		lineageTag: c1a00001-0001-0001-0001-000000000206
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsOrphaned = ISBLANK([Owner.Email])
		dataType: boolean
		lineageTag: c1a00001-0001-0001-0001-000000000207
		summarizeBy: none
		formatString: """TRUE"";""TRUE"";""FALSE"""

		annotation SummarizationSetBy = Automatic

	column HasSensitivityLabel = NOT(ISBLANK([SensitivityLabelInfo.Id]))
		dataType: boolean
		lineageTag: c1a00001-0001-0001-0001-000000000208
		summarizeBy: none
		formatString: """TRUE"";""TRUE"";""FALSE"""

		annotation SummarizationSetBy = Automatic

	column StorageUtilizationPct = DIVIDE([StorageUsed], [StorageQuota], 0) * 100
		dataType: double
		lineageTag: c1a00001-0001-0001-0001-000000000209
		summarizeBy: none
		formatString: #,0.00

		annotation SummarizationSetBy = Automatic

	column SiteAgeCategory = SWITCH(TRUE(), DATEDIFF([CreatedTime], TODAY(), DAY) < 90, "New", DATEDIFF([CreatedTime], TODAY(), DAY) < 365, "Recent", DATEDIFF([CreatedTime], TODAY(), DAY) < 730, "Established", "Mature")
		dataType: string
		lineageTag: c1a00001-0001-0001-0001-000000000210
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsOverprovisioned = [StorageUtilizationPct] < 5 && [StorageQuota] > 1073741824
		dataType: boolean
		lineageTag: c1a00001-0001-0001-0001-000000000211
		summarizeBy: none
		formatString: """TRUE"";""TRUE"";""FALSE"""

		annotation SummarizationSetBy = Automatic

	partition SPOSites = entity
		mode: directQuery
		source
			entityName: SPOSites
			expressionSource: 'DirectQuery to AS - MGDC'
