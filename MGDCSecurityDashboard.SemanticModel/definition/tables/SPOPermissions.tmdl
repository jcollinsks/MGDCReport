		summarizeBy: none
		sourceColumn: SnapshotDate

		annotation SummarizationSetBy = Automatic

	column IsAnonymousLink = [LinkScope] = "Anyone"
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678920
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsExternalShare = [LinkScope] = "Anyone"
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678921
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column HasNoExpiration = ISBLANK([ShareExpirationTime])
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678922
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column PermissionRiskLevel =
			SWITCH(
				TRUE(),
				[IsAnonymousLink] && [RoleDefinition] IN {"Write", "Full Control"}, "Critical",
				[IsAnonymousLink], "High",
				[IsExternalShare] && [HasNoExpiration], "High",
				[IsExternalShare], "Medium",
				"Low"
			)
		dataType: string
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678923
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column PermissionRiskScore = SWITCH([PermissionRiskLevel], "Critical", 100, "High", 75, "Medium", 50, 25)
		dataType: int64
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678924
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsOverprivileged = [RoleDefinition] IN {"Full Control", "Write"} && [IsAnonymousLink]
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678925
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column PermissionAgeCategory =
			SWITCH(
				TRUE(),
				DATEDIFF([ShareCreatedTime], TODAY(), DAY) < 30, "New",
				DATEDIFF([ShareCreatedTime], TODAY(), DAY) < 90, "Recent",
				DATEDIFF([ShareCreatedTime], TODAY(), DAY) < 365, "Standard",
				DATEDIFF([ShareCreatedTime], TODAY(), DAY) < 730, "Old",
				"Ancient"
			)
		dataType: string
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678926
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column PermissionAgeDays = DATEDIFF([ShareCreatedTime], TODAY(), DAY)
		dataType: int64
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678927
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column DaysUntilExpiry = IF(ISBLANK([ShareExpirationTime]), BLANK(), DATEDIFF(TODAY(), [ShareExpirationTime], DAY))
		dataType: int64
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678928
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsExpiringSoon = NOT(ISBLANK([ShareExpirationTime])) && [DaysUntilExpiry] <= 30 && [DaysUntilExpiry] > 0
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678929
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column LinkCategory = IF(ISBLANK([LinkScope]), "Direct", [LinkScope])
		dataType: string
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f1234567892a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition SPOPermissions = entity
		mode: directQuery
		source
			entityName: SPOPermissions
			expressionSource: 'DirectQuery to AS - MGDC'
