		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000113
		summarizeBy: none
		sourceColumn: 'SensitivityLabelInfo.Id'

		annotation SummarizationSetBy = Automatic

	column 'SensitivityLabelInfo.DisplayName'
		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000114
		summarizeBy: none
		sourceColumn: 'SensitivityLabelInfo.DisplayName'

		annotation SummarizationSetBy = Automatic

	column IsLabelEncrypted
		dataType: boolean
		lineageTag: c1a00002-0001-0001-0001-000000000115
		summarizeBy: none
		sourceColumn: IsLabelEncrypted
		formatString: """TRUE"";""TRUE"";""FALSE"""

		annotation SummarizationSetBy = Automatic

