	column DirName
		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000118
		summarizeBy: none
		sourceColumn: DirName

		annotation SummarizationSetBy = Automatic

	column SiteUrl
		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000119
		summarizeBy: none
		sourceColumn: SiteUrl

		annotation SummarizationSetBy = Automatic

	column WebId
		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000120
		summarizeBy: none
		sourceColumn: WebId

		annotation SummarizationSetBy = Automatic

	column ListId
		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000121
		summarizeBy: none
		sourceColumn: ListId

		annotation SummarizationSetBy = Automatic

	column SnapshotDate
		dataType: dateTime
		lineageTag: c1a00002-0001-0001-0001-000000000122
		summarizeBy: none
		sourceColumn: SnapshotDate
		formatString: General Date

		annotation SummarizationSetBy = Automatic

	column FileSizeMB = DIVIDE([SizeInBytes], 1048576, 0)
		dataType: double
		lineageTag: c1a00002-0001-0001-0001-000000000201
		summarizeBy: none
		formatString: #,0.00

		annotation SummarizationSetBy = Automatic

	column FileCategory = SWITCH(TRUE(), [Extension] IN {".docx", ".doc", ".odt", ".rtf"}, "Documents", [Extension] IN {".xlsx", ".xls", ".csv"}, "Spreadsheets", [Extension] IN {".pptx", ".ppt"}, "Presentations", [Extension] IN {".pdf"}, "PDFs", [Extension] IN {".jpg", ".png", ".gif", ".bmp", ".svg"}, "Images", "Other")
		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000202
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column SecurityStatus =
		SWITCH(TRUE(), [HasSensitivityLabel] && [IsLabelEncrypted], "Protected", [IsLabelEncrypted], "Encrypted Only", [HasSensitivityLabel], "Labeled Only", "Unprotected")
		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000203
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column HasSensitivityLabel = NOT(ISBLANK([SensitivityLabelInfo.Id]))
		dataType: boolean
		lineageTag: c1a00002-0001-0001-0001-000000000204
		summarizeBy: none
		formatString: """TRUE"";""TRUE"";""FALSE"""

		annotation SummarizationSetBy = Automatic

	column FileAgeCategory = SWITCH(TRUE(), DATEDIFF([TimeCreated], TODAY(), DAY) < 30, "New", DATEDIFF([TimeCreated], TODAY(), DAY) < 90, "Recent", DATEDIFF([TimeCreated], TODAY(), DAY) < 365, "Standard", DATEDIFF([TimeCreated], TODAY(), DAY) < 730, "Old", "Ancient")
		dataType: string
		lineageTag: c1a00002-0001-0001-0001-000000000205
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsLargeFile = [SizeInBytes] > 104857600
		dataType: boolean
		lineageTag: c1a00002-0001-0001-0001-000000000206
		summarizeBy: none
		formatString: """TRUE"";""TRUE"";""FALSE"""

		annotation SummarizationSetBy = Automatic

	column VersionBloatRatio = DIVIDE([SizeInBytesWithVersions], [SizeInBytes], 0)
		dataType: double
		lineageTag: c1a00002-0001-0001-0001-000000000207
		summarizeBy: none
		formatString: #,0.00

		annotation SummarizationSetBy = Automatic

	column DaysSinceModified = DATEDIFF([TimeLastModified], TODAY(), DAY)
		dataType: int64
		lineageTag: c1a00002-0001-0001-0001-000000000208
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsStale = [DaysSinceModified] > 180
		dataType: boolean
		lineageTag: c1a00002-0001-0001-0001-000000000209
		summarizeBy: none
		formatString: """TRUE"";""TRUE"";""FALSE"""

		annotation SummarizationSetBy = Automatic

	column FileRiskScore =
		VAR _NoLabel = IF(ISBLANK([SensitivityLabelInfo.Id]), 30, 0)
		VAR _NoEncryption = IF(NOT([IsLabelEncrypted]), 20, 0)
		VAR _Stale = IF(DATEDIFF([TimeLastModified], TODAY(), DAY) > 180, 15, 0)
		VAR _LargeFile = IF([SizeInBytes] > 104857600, 10, 0)
		VAR _VersionBloat = IF(DIVIDE([SizeInBytesWithVersions], [SizeInBytes], 0) > 10, 15, 0)
		VAR _ExternalPath = IF(CONTAINSSTRING([DirName], "/External/") || CONTAINSSTRING([DirName], "/Shared with Everyone/"), 10, 0)
		RETURN _NoLabel + _NoEncryption + _Stale + _LargeFile + _VersionBloat + _ExternalPath
		dataType: int64
		lineageTag: c1a00002-0001-0001-0001-000000000210
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition SPOFiles = entity
		mode: directQuery
		source
			entityName: SPOFiles
			expressionSource: 'DirectQuery to AS - MGDC'
