	column ActionHour = HOUR([ActionDate])
		dataType: int64
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567821
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsWeekend = WEEKDAY([ActionDate], 2) > 5
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567822
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsAfterHours = OR(HOUR([ActionDate]) < 7, HOUR([ActionDate]) > 19)
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567823
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsHighRiskAction = [ActionName] IN {"FileDeleted", "PermissionChanged", "SharingSet", "FileVersionsAllDeleted", "FileMalwareDetected"}
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567824
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsExternalUser = [ActorType] = "External"
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567840
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsSuspiciousActivity = [IsAfterHours] && [IsExternalUser] && [IsHighRiskAction]
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567825
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column ActionCategory =
			SWITCH(
				TRUE(),
				[ActionName] IN {"FileAccessed", "FileCheckedOut"}, "Read",
				[ActionName] IN {"FileModified", "FileUploaded", "FileRenamed", "FileMoved", "FileCheckedIn"}, "Write",
				[ActionName] IN {"FileDeleted", "FileVersionsAllDeleted"}, "Delete",
				"Manage"
			)
		dataType: string
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567826
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column UserAgentCategory =
			SWITCH(
				TRUE(),
				CONTAINSSTRING([UserAgent], "Teams"), "Teams",
				CONTAINSSTRING([UserAgent], "OneDrive"), "OneDrive",
				CONTAINSSTRING([UserAgent], "Mozilla") || CONTAINSSTRING([UserAgent], "Chrome") || CONTAINSSTRING([UserAgent], "Edge"), "Browser",
				CONTAINSSTRING([UserAgent], "Mobile") || CONTAINSSTRING([UserAgent], "Android") || CONTAINSSTRING([UserAgent], "iOS"), "Mobile",
				CONTAINSSTRING([UserAgent], "CSOM") || CONTAINSSTRING([UserAgent], "Microsoft Office"), "API",
				"Other"
			)
		dataType: string
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567827
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsExternalDownload = [IsExternalUser] && [ActionName] = "FileAccessed"
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567828
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column TimePeriod =
			SWITCH(
				TRUE(),
				[ActionHour] >= 6 && [ActionHour] < 12, "Morning",
				[ActionHour] >= 12 && [ActionHour] < 17, "Afternoon",
				[ActionHour] >= 17 && [ActionHour] < 21, "Evening",
				"Night"
			)
		dataType: string
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567829
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition SPOFileActions = entity
		mode: directQuery
		source
			entityName: SPOFileActions
			expressionSource: 'DirectQuery to AS - MGDC'
